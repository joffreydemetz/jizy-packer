@import (optional) url("less/theme.less");
@import (optional) url("less/animations.less");
@import (optional) url("less/structure.less");

@container (max-width: 767px) {
    @import (optional) url("less/mobile.less");
}

@container (min-width: 768px) {
    @import (optional) url("less/screen.less");
}

@media print {
    @import (optional) url("less/print.less");
}
